{
  "appId": "com.apnadecoration.vendor",
  "appName": "APNA Decoration - Vendor Panel",
  "webDir": "public",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": true,
    "plugins": {
      "CapacitorHttp": {
        "enabled": true,
        "allowUrlList": [
          "https://user-api.apnadecoration.com",
          "https://admin-api.apnadecoration.com"
        ]
      }
    }
  },
  "hosts": [
    {
      "hostname": "user-api.apnadecoration.com",
      "scheme": "https"
    },
    {
      "hostname": "admin-api.apnadecoration.com",
      "scheme": "https"
    }
  ],
  "android": {
    "allowMixedContent": true,
    "webSecurity": {
      "allowContentAccess": true,
      "allowFileAccess": true
    }
  }
}
