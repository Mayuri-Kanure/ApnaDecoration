{
  "name": "apna-decoration-backend",
  "version": "1.0.0",
  "description": "Backend API for APNA Decoration E-commerce Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "migrate": "sequelize-cli db:migrate",
    "seed": "sequelize-cli db:seed:all",
    "reset": "sequelize-cli db:migrate:undo:all && npm run migrate && npm run seed",
    "migrate-to-atlas": "node scripts/migrate-to-atlas.js",
    "create-admin-atlas": "node scripts/create-admin-atlas.js",
    "create-sample-data": "node scripts/create-sample-data.js"
  },
  "keywords": [
    "decoration",
    "ecommerce",
    "event",
    "nodejs",
    "express",
    "sequelize"
  ],
  "author": "APNA Decoration Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "mongoose": "^8.3.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.9.7",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "razorpay": "^2.9.4",
    "sequelize": "^6.37.3",
    "sharp": "^0.33.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "mongodb-memory-server": "^8.12.2",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  }
}
